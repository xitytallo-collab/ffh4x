local function CreateTabButton(name, emoji, startsActive)
    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(1, 0, 0, 32)
    Button.Font = Enum.Font.GothamBold
    Button.TextSize = 13
    Button.TextXAlignment = Enum.TextXAlignment.Left
    Button.BackgroundColor3 = Color3.fromRGB(15, 19, 29)
    Button.RichText = true
    
    local NeonStroke = Instance.new("UIStroke")
    NeonStroke.Color = Color3.fromRGB(0, 255, 127) 
    NeonStroke.Thickness = 1.5
    NeonStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    NeonStroke.Enabled = false
    NeonStroke.Parent = Button

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 5)
    BtnCorner.Parent = Button
    Button.Parent = LeftPanel

    local function applyState(isActive)
        if isActive then
            Button.Text = "  " .. emoji .. "  <font color='rgb(255,255,255)'>" .. name .. "</font>"
            NeonStroke.Enabled = true
        else
            Button.Text = "  " .. emoji .. "  <font color='rgb(160,160,160)'>" .. name .. "</font>"
            NeonStroke.Enabled = false
        end
    end

    Button.MouseButton1Click:Connect(function()
        for _, tData in ipairs(tabButtons) do
            tData.Update(false)
        end
        applyState(true)
        HandleTabChange(name)
    end)

    applyState(startsActive)
    table.insert(tabButtons, {Button = Button, Update = applyState})
end

