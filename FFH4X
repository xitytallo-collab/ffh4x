-- Motor de Expandir Hitbox Cabeça
_G.HitboxConnection = game:GetService("RunService").Heartbeat:Connect(function()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local head = player.Character:FindFirstChild("Head")
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if head and head:IsA("BasePart") and humanoid and humanoid.Health > 0 then
                if not OriginalSizes[player] then OriginalSizes[player] = head.Size end
                if ScriptSettings.AimbotEnabled and ScriptSettings.HitboxHeadEnabled and ScriptSettings.HitboxSize > 0 then
                    local targetScale = 1 + (ScriptSettings.HitboxSize * 0.8)
                    head.Size = Vector3.new(targetScale, targetScale, targetScale)
                    head.CanCollide = false
                    head.Transparency = 0.4 
                else
                    if OriginalSizes[player] then head.Size = OriginalSizes[player]; head.Transparency = 0 end
                end
            end
        end
    end
end)

-- Renderizador do ESP (Linha saindo do Topo)
local function ObterCorVisibilidade(targetPart, targetCharacter)
    local origem = Camera.CFrame.Position
    local direcao = targetPart.Position - origem
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    local resultado = Workspace:Raycast(origem, direcao, params)
    if resultado and resultado.Instance:IsDescendantOf(targetCharacter) then return Color3.fromRGB(0, 255, 127) end
    return Color3.fromRGB(255, 30, 30) 
end

local function CreateESP(player)
    if player == LocalPlayer then return end
    local objects = {
        Box = Drawing.new("Square"), Line = Drawing.new("Line"),
        Name = Drawing.new("Text"), Distance = Drawing.new("Text"),
        HealthBg = Drawing.new("Square"), HealthBar = Drawing.new("Square")
    }
    objects.Box.Visible = false; objects.Box.Thickness = ScriptSettings.Thickness; objects.Box.Filled = false
    objects.Line.Visible = false; objects.Line.Thickness = ScriptSettings.Thickness
    objects.Name.Visible = false; objects.Name.Color = Color3.fromRGB(255,255,255); objects.Name.Size = 13; objects.Name.Center = true; objects.Name.Outline = false
    objects.Distance.Visible = false; objects.Distance.Color = Color3.fromRGB(255,255,255); objects.Distance.Size = 12; objects.Distance.Center = true; objects.Distance.Outline = false
    objects.HealthBg.Visible = false; objects.HealthBg.Color = Color3.fromRGB(40, 40, 40); objects.HealthBg.Filled = true
    objects.HealthBar.Visible = false; objects.HealthBar.Filled = true
    _G.ESPObjects[player] = objects
end

local function RemoveESP(player)
    if _G.ESPObjects[player] then
        _G.ESPObjects[player].Box:Remove(); _G.ESPObjects[player].Line:Remove(); _G.ESPObjects[player].Name:Remove()
        _G.ESPObjects[player].Distance:Remove(); _G.ESPObjects[player].HealthBg:Remove(); _G.ESPObjects[player].HealthBar:Remove()
        _G.ESPObjects[player] = nil
    end
end

for _, p in ipairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)
Players.PlayerRemoving:Connect(RemoveESP)

_G.ESPConnection = game:GetService("RunService").RenderStepped:Connect(function()
    if not ScriptSettings.ESPEnabled then
        for _, obj in pairs(_G.ESPObjects) do
            obj.Box.Visible = false; obj.Line.Visible = false; obj.Name.Visible = false; obj.Distance.Visible = false; obj.HealthBg.Visible = false; obj.HealthBar.Visible = false
        end
        return
    end

    for player, obj in pairs(_G.ESPObjects) do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        
        if char and hrp and humanoid and humanoid.Health > 0 then
            local hrpPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local corDinamica = ObterCorVisibilidade(hrp, char)
                local distance = (Camera.CFrame.Position - hrp.Position).Magnitude
                local scale = (1 / distance) * 1000
                local width = math.clamp(scale * 1.6, 10, 500)
                local height = math.clamp(scale * 2.2, 15, 700)
                local boxX = hrpPos.X - (width / 2)
                local boxY = hrpPos.Y - (height / 2)
                
                if ScriptSettings.ESPBox then
                    obj.Box.Size = Vector2.new(width, height)
                    obj.Box.Position = Vector2.new(boxX, boxY)
                    obj.Box.Color = corDinamica
                    obj.Box.Visible = true
                else obj.Box.Visible = false end
                
                if ScriptSettings.ESPLine then
                    -- MODIFICADO: Agora sai do Topo Central (X / 2, Y = 0)
                    obj.Line.From = Vector2.new(Camera.ViewportSize.X / 2, 0)
                    obj.Line.To = Vector2.new(hrpPos.X, hrpPos.Y)
                    obj.Line.Color = corDinamica
                    obj.Line.Visible = true
                else obj.Line.Visible = false end
                
                if ScriptSettings.ESPName then
                    obj.Name.Text = player.Name
                    obj.Name.Position = Vector2.new(hrpPos.X, boxY - 16)
                    obj.Name.Visible = true
                else obj.Name.Visible = false end
                
                if ScriptSettings.ESPDistance then
                    obj.Distance.Text = math.floor(distance) .. " studs"
                    obj.Distance.Position = Vector2.new(hrpPos.X, boxY + height + 2)
                    obj.Distance.Visible = true
                else obj.Distance.Visible = false end
                
                if ScriptSettings.ESPHealth then
                    local healthPct = humanoid.Health / humanoid.MaxHealth
                    local barHeight = height * healthPct
                    obj.HealthBg.Size = Vector2.new(3, height)
                    obj.HealthBg.Position = Vector2.new(boxX - 6, boxY)
                    obj.HealthBg.Visible = true
                    
                    obj.HealthBar.Size = Vector2.new(3, barHeight)
                    obj.HealthBar.Position = Vector2.new(boxX - 6, boxY + height - barHeight)
                    obj.HealthBar.Color = Color3.fromRGB(0, 255, 127)
                    obj.HealthBar.Visible = true
                else obj.HealthBg.Visible = false; obj.HealthBar.Visible = false end
            else
                obj.Box.Visible = false; obj.Line.Visible = false; obj.Name.Visible = false; obj.Distance.Visible = false; obj.HealthBg.Visible = false; obj.HealthBar.Visible = false
            end
        else
            obj.Box.Visible = false; obj.Line.Visible = false; obj.Name.Visible = false; obj.Distance.Visible = false; obj.HealthBg.Visible = false; obj.HealthBar.Visible = false
        end
    end
end)
